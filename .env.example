# ============================================================
# Moto-GPS — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# Required keys are marked with [REQUIRED].
# Optional keys enhance functionality but aren't needed to run.
# ============================================================

# --- Database (PostGIS) ---
POSTGRES_USER=motogps
POSTGRES_PASSWORD=motogps_dev
POSTGRES_DB=motogps
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

# --- Service URLs ---
VALHALLA_URL=http://localhost:8010
MARTIN_URL=http://localhost:3002
BACKEND_URL=http://localhost:8000

# --- [REQUIRED] MapTiler API Key ---
# Free tier: https://www.maptiler.com/cloud/ (sign up, create a key)
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_key_here

# --- [REQUIRED] JWT Authentication ---
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# --- Admin Seed User ---
# Used by: cd backend && python -m app.cli.seed_admin
ADMIN_EMAIL=admin@motogps.local
ADMIN_NAME=Admin
ADMIN_PASSWORD=change-me-in-production

# --- [RECOMMENDED] AI Trip Planner ---
# Get a free Gemini API key: https://aistudio.google.com/apikey
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- [OPTIONAL] Google Places API ---
# Enables POI photo enrichment on click. Costs ~$0.03/request.
# https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=
